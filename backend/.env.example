# Garmin Connect credentials
# Copy this file to .env and fill in your credentials
# NEVER commit .env to git

GARMIN_EMAIL=your_email@example.com
GARMIN_PASSWORD=your_password

# Optional: path to store OAuth tokens (default: ~/.garminconnect)
# GARMIN_TOKEN_STORE=~/.garminconnect

# ----- LLM coach (OpenAI-compatible endpoint; host-swappable) -----
# Point these at whatever runs the model. Defaults target a local Ollama.
# On the Mac: install Ollama, `ollama pull llama3.1:8b`, and leave the default
# base URL. Any OpenAI-compatible server works (mlx-lm, LM Studio, llama.cpp).
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.1:8b
# LLM_API_KEY=ollama   # Ollama ignores this; kept for OpenAI-compatible shape
